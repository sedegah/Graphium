{
  "name": "graphium",
  "displayName": "Graphium",
  "publisher": "KimathiSedegah",
  "icon": "1.png",
  "description": "Dependency graph generator for codebases",
  "version": "0.2.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sedegah/graphium"
  },
  "homepage": "https://github.com/sedegah/Graphium#readme",
  "bugs": {
    "url": "https://github.com/sedegah/Graphium/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "graph",
    "dependency",
    "visualization",
    "dependency-graph",
    "typescript",
    "javascript",
    "architecture",
    "cytoscape",
    "code-visualization"
  ],
  "files": [
    "out/**",
    "media/**",
    "src/webview/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "1.png"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "graphium-explorer",
          "title": "Graphium",
          "icon": "media/graphium-sidebar.svg"
        }
      ]
    },
    "views": {
      "graphium-explorer": [
        {
          "type": "webview",
          "id": "graphiumSidebar",
          "name": "Graphium Tools",
          "icon": "media/graphium-sidebar.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "graphium.generateGraph",
        "title": "Graphium: Generate Dependency Graph"
      },
      {
        "command": "graphium.refreshGraph",
        "title": "Graphium: Refresh Graph"
      },
      {
        "command": "graphium.exportGraph",
        "title": "Graphium: Export Graph"
      },
      {
        "command": "graphium.toggleFilter",
        "title": "Graphium: Toggle Filter"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@popperjs/core": "^2.11.8",
    "cose-base": "^2.2.0",
    "cytoscape": "^3.33.1",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-popper": "^4.0.1",
    "layout-base": "^2.0.1",
    "tippy.js": "^6.3.7"
  }
}
